{
  "nodeModulesDir": "manual",
  "imports": {
    "@peculiar/x509": "npm:@peculiar/x509@^2.0.0",
    "reflect-metadata": "npm:reflect-metadata@^0.2.2",
    "@paulmillr/qr": "jsr:@paulmillr/qr@^0.6.0"
  },
  "tasks": {
    "setup": "deno install",
    "qr": "deno run -A qr-assets.ts",
    "practice": "deno run -A --unstable-net server.ts",
    "practice:watch": "deno run -A --unstable-net --watch server.ts",
    "workshop": "MODE=workshop deno run -A --unstable-net server.ts",
    "workshop:watch": "MODE=workshop deno run -A --unstable-net --watch server.ts",
    "performance": "MODE=performance deno run -A --unstable-net server.ts",
    "performance:watch": "MODE=performance deno run -A --unstable-net --watch server.ts",
    "start": "deno run -A --unstable-net server.ts"
  }
}
